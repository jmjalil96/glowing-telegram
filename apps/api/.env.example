NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/techbros_api
# Required in production. Leave empty in development/test to use localhost defaults.
CORS_ALLOWED_ORIGINS=
WEB_APP_URL=http://localhost:5173
LOG_LEVEL=debug
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=5000
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_REPLY_TO=
