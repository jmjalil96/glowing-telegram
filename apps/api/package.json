{
  "name": "@techbros/api",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/tsconfig.json",
    "lint": "pnpm --dir ../.. exec eslint apps/api --max-warnings=0",
    "lint:fix": "pnpm --dir ../.. exec eslint apps/api --fix --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "docker compose -f ../../docker-compose.yml up -d postgres inbucket",
    "db:down": "docker compose -f ../../docker-compose.yml down",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts"
  },
  "dependencies": {
    "compression": "1.8.1",
    "cors": "2.8.6",
    "dotenv-flow": "4.1.0",
    "drizzle-orm": "0.45.2",
    "express": "5.2.1",
    "helmet": "8.1.0",
    "nodemailer": "^8.0.5",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/compression": "1.8.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "24.12.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "8.15.6",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "0.31.10",
    "supertest": "^7.2.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "^4.1.4"
  }
}
