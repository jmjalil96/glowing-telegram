{
  "name": "techbros-workspace",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --stream --filter @techbros/api --filter @techbros/web run dev",
    "dev:api": "pnpm --filter @techbros/api run dev",
    "dev:web": "pnpm --filter @techbros/web run dev",
    "build": "pnpm --filter @techbros/api --filter @techbros/web run build",
    "build:api": "pnpm --filter @techbros/api run build",
    "build:web": "pnpm --filter @techbros/web run build",
    "start": "pnpm --filter @techbros/api run start",
    "typecheck": "pnpm --filter @techbros/api --filter @techbros/web run typecheck",
    "typecheck:api": "pnpm --filter @techbros/api run typecheck",
    "typecheck:web": "pnpm --filter @techbros/web run typecheck",
    "test": "pnpm --filter @techbros/api run test && pnpm --filter @techbros/web run test",
    "test:coverage": "pnpm --filter @techbros/api run test:coverage && pnpm --filter @techbros/web run test:coverage",
    "test:watch": "pnpm --parallel --stream --filter @techbros/api --filter @techbros/web run test:watch",
    "lint": "pnpm --filter @techbros/api --filter @techbros/web run lint",
    "lint:fix": "pnpm --filter @techbros/api --filter @techbros/web run lint:fix",
    "preview:web": "pnpm --filter @techbros/web run preview",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10 <11"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.2.0",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "prettier": "3.8.2",
    "typescript-eslint": "8.58.1"
  }
}
